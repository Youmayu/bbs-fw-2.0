<Window x:Class="BBSFW.View.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BBS-FW Tool"
        Width="520"
        Height="300"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent">

	<Border CornerRadius="8"
			Background="{DynamicResource SurfaceBrush}"
			BorderBrush="{DynamicResource BorderBrush}"
			BorderThickness="1"
			SnapsToDevicePixels="True">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

			<Border Grid.Row="0"
					CornerRadius="8 8 0 0"
					Background="{DynamicResource SplashGradientBrush}"
					Padding="34">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>

					<StackPanel Orientation="Horizontal">
						<Border Width="54"
								Height="54"
								CornerRadius="8"
								Background="{DynamicResource LogoGradientBrush}">
							<TextBlock Text="B"
									   FontSize="27"
									   FontWeight="Bold"
									   Foreground="{DynamicResource LogoTextBrush}"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center" />
						</Border>
						<StackPanel Margin="16 0 0 0" VerticalAlignment="Center">
							<TextBlock Text="BBS-FW Tool"
									   FontSize="25"
									   FontWeight="SemiBold"
									   Foreground="{DynamicResource HeaderTextBrush}" />
							<TextBlock Text="{DynamicResource Loc.Splash.ControllerConfig}"
									   FontSize="13"
									   Foreground="{DynamicResource HeaderMutedTextBrush}" />
						</StackPanel>
					</StackPanel>

					<TextBlock Grid.Row="2"
							   Text="{DynamicResource Loc.Splash.PreparingWorkspace}"
							   FontSize="13"
							   Foreground="{DynamicResource HeaderMutedTextBrush}" />
				</Grid>
			</Border>

			<Grid Grid.Row="1" Margin="34 20 34 24">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
				</Grid.RowDefinitions>

				<TextBlock Text="{DynamicResource Loc.Splash.Summary}"
						   Foreground="{DynamicResource MutedTextBrush}" />
				<ProgressBar Grid.Row="1"
							 Height="6"
							 Margin="0 14 0 0"
							 IsIndeterminate="True" />
			</Grid>
		</Grid>
	</Border>
</Window>
